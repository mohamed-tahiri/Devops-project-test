pipeline {
    agent any

    environment {
        IMAGE_NAME = 'sentiment-ai'
        REGISTRY   = 'ghcr.io/mohamed-tahiri'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.IMAGE_TAG    = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    env.BRANCH_LABEL = sh(script: 'git name-rev --name-only HEAD | sed "s|remotes/origin/||"', returnStdout: true).trim()
                }
                echo "Branche   : ${env.BRANCH_LABEL}"
                echo "Commit    : ${env.GIT_COMMIT}"
                echo "Image Tag : ${env.IMAGE_TAG}"
                sh 'git log --oneline -5'
            }
        }

        stage('Lint') {
            steps {
                sh '''
                    docker run --rm \
                        --volumes-from jenkins \
                        -w "$WORKSPACE" \
                        python:3.12-slim \
                        sh -c "pip install flake8 -q && flake8 src/ --max-line-length=100 --exit-zero"
                '''
            }
        }

        stage('IaC Validate') {
            steps {
                dir('infra') {
                    // Analyse statique (Fail Fast) sur toutes les branches sans contacter de backend
                    sh 'terraform init -backend=false -input=false'
                    sh 'terraform fmt -check -recursive'
                    sh 'terraform validate'
                }
            }
        }

        stage('Build & Test') {
            steps {
                sh '''
                    docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .

                    # On crée un nom de conteneur unique basé sur le tag du commit
                    RUNNER_NAME="test-runner-${IMAGE_TAG}"

                    # Nettoyage par sécurité
                    docker rm -f $RUNNER_NAME 2>/dev/null || true

                    # Lancer les tests
                    set +e
                    docker run \
                        -e CI=true \
                        --name $RUNNER_NAME \
                        ${IMAGE_NAME}:${IMAGE_TAG} \
                        pytest tests/ -v \
                        --cov=src \
                        --cov-report=xml:/tmp/coverage.xml \
                        --cov-report=term-missing \
                        --cov-fail-under=70
                    TEST_EXIT_CODE=$?
                    set -e

                    # Copier le rapport depuis le conteneur unique vers le workspace
                    docker cp $RUNNER_NAME:/tmp/coverage.xml ./coverage.xml
                    COPY_EXIT_CODE=$?
                    docker rm -f $RUNNER_NAME 2>/dev/null || true

                    if [ $TEST_EXIT_CODE -ne 0 ]; then
                        echo "Tests échoués avec le code de sortie : $TEST_EXIT_CODE"
                        exit $TEST_EXIT_CODE
                    fi

                    if [ $COPY_EXIT_CODE -ne 0 ]; then
                        echo "Avertissement : coverage.xml introuvable dans le conteneur (analyse SonarQube sans couverture)"
                    fi
                '''
            }
            post {
                failure {
                    echo 'Tests échoués ou coverage insuffisant (< 70%)'
                }
            }
        }

        stage('SonarQube Analysis') {
            environment {
                SONARQUBE_TOKEN = credentials('sonar-token')
            }
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh '''
                        docker run --rm \
                            --network cicd-network \
                            --volumes-from jenkins \
                            -w "$WORKSPACE" \
                            -e SONAR_HOST_URL="$SONAR_HOST_URL" \
                            -e SONAR_TOKEN="$SONARQUBE_TOKEN" \
                            sonarsource/sonar-scanner-cli:latest \
                            sonar-scanner \
                            -Dsonar.projectKey=sentiment-ai \
                            -Dsonar.projectName=SentimentAI \
                            -Dsonar.projectBaseDir="$WORKSPACE" \
                            -Dsonar.sources=src \
                            -Dsonar.python.version=3.11 \
                            -Dsonar.python.coverage.reportPaths=coverage.xml \
                            -Dsonar.sourceEncoding=UTF-8 \
                            -Dsonar.scanner.metadataFilePath=$WORKSPACE/report-task.txt
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 15, unit: 'MINUTES') {
                    // Reçoit le statut mais ne fait pas crasher la pipeline en cas d'ERROR
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Security Scan (Trivy)') {
            steps {
                // --exit-code 0 : scanne et affiche le tableau sans bloquer (selon tes instructions)
                sh """
                    docker run --rm \
                        -v /var/run/docker.sock:/var/run/docker.sock \
                        -v trivy-cache:/root/.cache/trivy \
                        aquasec/trivy:latest image \
                        --severity HIGH,CRITICAL \
                        --exit-code 0 \
                        --format table \
                        ${IMAGE_NAME}:${env.IMAGE_TAG}
                """
            }
            post {
                failure {
                    echo 'Vulnérabilités CRITICAL ou HIGH détectées !'
                    echo 'Corrigez les dépendances avant de déployer.'
                }
            }
        }

        stage('Push') {
            when { expression { env.BRANCH_LABEL == 'main' } }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-token',
                    usernameVariable: 'REGISTRY_USER',
                    passwordVariable: 'REGISTRY_PASS'
                )]) {
                    sh """
                        echo \$REGISTRY_PASS | docker login ghcr.io -u \$REGISTRY_USER --password-stdin
                        docker tag ${IMAGE_NAME}:${env.IMAGE_TAG} ${REGISTRY}/${IMAGE_NAME}:${env.IMAGE_TAG}
                        docker push ${REGISTRY}/${IMAGE_NAME}:${env.IMAGE_TAG}
                    """
                }
            }
        }

        stage('IaC Apply') {
            when { expression { env.BRANCH_LABEL == 'main' } }
            steps {
                dir('infra') {
                    // Initialisation réelle du provider Docker et application de l'infrastructure
                    sh 'terraform init -input=false'
                    sh """
                        terraform apply -auto-approve \
                            -var='image_tag=${env.IMAGE_TAG}'
                    """
                }
            }
        }

        stage('Deploy Staging') {
            when { expression { env.BRANCH_LABEL == 'main' } }
            steps {
                // S'assure que le conteneur déployé par Terraform répond correctement sur le port 8001
                sh 'curl -f http://localhost:8001/health || exit 1'
                echo "Staging disponible sur http://localhost:8001"
            }
        }
    }

    post {
        always {
            sh 'docker compose down -v 2>/dev/null || true'
        }
        success {
            echo "Pipeline réussi ! Image publiée et déployée via Terraform : ${REGISTRY}/${IMAGE_NAME}:${env.IMAGE_TAG}"
        }
        failure {
            echo 'Pipeline échoué. Consultez les logs Jenkins.'
        }
    }
}