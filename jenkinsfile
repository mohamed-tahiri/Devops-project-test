pipeline {
    agent any

    environment {
        IMAGE_NAME = 'sentiment-ai'
        REGISTRY   = 'ghcr.io/mohamed-tahiri'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.IMAGE_TAG    = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    env.BRANCH_LABEL = sh(script: 'git name-rev --name-only HEAD | sed "s|remotes/origin/||"', returnStdout: true).trim()
                }
                echo "Branche   : ${env.BRANCH_LABEL}"
                echo "Commit    : ${env.GIT_COMMIT}"
                echo "Image Tag : ${env.IMAGE_TAG}"
                sh 'git log --oneline -5'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t ${IMAGE_NAME}:${env.IMAGE_TAG} ."
            }
        }

        stage('Tests & Coverage') {
            steps {
                script {
                    // On définit un nom unique pour le conteneur de test
                    def containerName = "${IMAGE_NAME}-tests-${env.BUILD_NUMBER}"
                    
                    try {
                        // 1. On lance le conteneur SANS montage de volume encombrant
                        sh """
                            docker run --name ${containerName} \
                                ${IMAGE_NAME}:${env.IMAGE_TAG} \
                                pytest tests/ -v \
                                --cov=src \
                                --cov-report=xml:coverage.xml \
                                --cov-report=term-missing \
                                --cov-fail-under=70
                        """
                    } finally {
                        // 2. Qu'il y ait succès ou échec, on extrait le fichier XML généré à l'intérieur du conteneur
                        sh "docker cp ${containerName}:/app/coverage.xml ./coverage.xml || true"
                        
                        // 3. On nettoie le conteneur pour ne pas saturer l'espace
                        sh "docker rm -f ${containerName} || true"
                    }
                    
                    // Vérification visuelle dans les logs
                    sh 'ls -la coverage.xml'
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'coverage.xml', allowEmptyArchive: true, fingerprint: true
                }
                failure {
                    echo 'Tests échoués ou couverture insuffisante (< 70%)'
                }
            }
        }

        stage('SonarQube Analysis') {
            when {
                expression { env.BRANCH_LABEL == 'main' }
            }
            steps {
                withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN')]) {
                    sh """
                        sonar-scanner \
                            -Dsonar.host.url=http://172.17.0.1:9000 \
                            -Dsonar.token=\$SONAR_TOKEN \
                            -Dsonar.projectKey=sentiment-ai \
                            -Dsonar.sources=src \
                            -Dsonar.python.coverage.reportPaths=coverage.xml \
                            -Dsonar.scanner.skipJreProvisioning=true \
                            -X
                    """
                }
            }
        }

        stage('Trivy Scan') {
            when {
                expression { env.BRANCH_LABEL == 'main' }
            }
            steps {
                sh """
                    trivy image \
                        --severity HIGH,CRITICAL \
                        --exit-code 1 \
                        ${IMAGE_NAME}:${env.IMAGE_TAG}
                """
            }
        }

        stage('Push Image') {
            when {
                expression { env.BRANCH_LABEL == 'main' }
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-token',
                    usernameVariable: 'REGISTRY_USER',
                    passwordVariable: 'REGISTRY_PASS'
                )]) {
                    sh """
                        echo \$REGISTRY_PASS | docker login ghcr.io -u \$REGISTRY_USER --password-stdin

                        docker tag ${IMAGE_NAME}:${env.IMAGE_TAG} ${REGISTRY}/${IMAGE_NAME}:${env.IMAGE_TAG}
                        docker push ${REGISTRY}/${IMAGE_NAME}:${env.IMAGE_TAG}

                        docker tag ${IMAGE_NAME}:${env.IMAGE_TAG} ${REGISTRY}/${IMAGE_NAME}:latest
                        docker push ${REGISTRY}/${IMAGE_NAME}:latest
                    """
                }
            }
        }
    }

    post {
        always {
            sh 'docker compose down -v 2>/dev/null || true'
        }
        success {
            echo "Pipeline réussi ! Image publiée : ${REGISTRY}/${IMAGE_NAME}:${env.IMAGE_TAG}"
        }
        failure {
            echo 'Pipeline échoué. Consultez les logs Jenkins.'
        }
    }
}